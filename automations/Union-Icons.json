{
  "version": 1,
  "automation": {
    "name": "Union Icons",
    "emoji": "🤖",
    "steps": [
      {
        "actionType": "sourceFromSelection",
        "params": {},
        "enabled": true,
        "outputName": "selection"
      },
      {
        "actionType": "flattenDescendants",
        "params": {},
        "enabled": true,
        "outputName": "descendants"
      },
      {
        "actionType": "filter",
        "params": {
          "logic": "or",
          "conditions": [
            {
              "field": "type",
              "operator": "equals",
              "value": "COMPONENT"
            },
            {
              "field": "name",
              "operator": "contains",
              "value": "@20x20"
            }
          ]
        },
        "enabled": true,
        "outputName": "filtered"
      },
      {
        "actionType": "repeatWithEach",
        "params": {
          "source": "nodes",
          "itemVar": "item",
          "onMismatch": "error",
          "resultMode": "originalNodes"
        },
        "enabled": true,
        "children": [
          {
            "actionType": "expandToChildren",
            "params": {},
            "enabled": true,
            "outputName": "children"
          },
          {
            "actionType": "count",
            "params": {
              "label": "Count"
            },
            "enabled": true,
            "outputName": "count2",
            "input": "children"
          },
          {
            "actionType": "ifCondition",
            "params": {
              "left": "{$count2}",
              "operator": "greaterThan",
              "right": "1",
              "logic": "or",
              "conditions": [
                {
                  "left": "{$count2}",
                  "operator": "greaterThan",
                  "right": "1"
                },
                {
                  "left": "{#children.type}",
                  "operator": "notEquals",
                  "right": "BOOLEAN_OPERATION"
                }
              ]
            },
            "enabled": true,
            "children": [
              {
                "actionType": "union",
                "params": {},
                "enabled": true,
                "outputName": "union"
              }
            ]
          },
          {
            "actionType": "ifCondition",
            "params": {
              "conditions": [
                {
                  "left": "{#children.type}",
                  "operator": "equals",
                  "right": "GROUP"
                },
                {
                  "left": "{#children.type}",
                  "operator": "greaterThan",
                  "right": "FRAME"
                }
              ],
              "logic": "and"
            },
            "enabled": true,
            "children": [
              {
                "actionType": "ungroup",
                "params": {},
                "enabled": true,
                "outputName": "nodes"
              }
            ]
          },
          {
            "actionType": "setName",
            "params": {
              "name": "stroke"
            },
            "enabled": true,
            "outputName": "named"
          },
          {
            "actionType": "setFillVariable",
            "params": {
              "variableName": "icon/icon-default-stroke"
            },
            "enabled": true,
            "outputName": "filled"
          }
        ]
      },
      {
        "actionType": "expandToChildren",
        "params": {},
        "enabled": true,
        "outputName": "children-2",
        "input": "filtered"
      },
      {
        "actionType": "selectResults",
        "params": {
          "scrollTo": true
        },
        "enabled": true,
        "outputName": "selected",
        "input": "children-2"
      }
    ]
  }
}